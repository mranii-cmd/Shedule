# Base de données (MariaDB/MySQL)
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=docsdb

# JWT
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# LDAP / AD (optionnel)
LDAP_URL=ldaps://ad.example.local:636
LDAP_BIND_DN=CN=svc-ldap,OU=svc,DC=example,DC=local
LDAP_BIND_PASSWORD=your_ldap_password_here
LDAP_USER_SEARCH_BASE=OU=Users,DC=example,DC=local
LDAP_USE_SSL=true
LDAP_USERNAME_ATTRIBUTE=sAMAccountName

# Mapping LDAP groups -> roles (format: AD_CN=role,AD_CN2=role2)
# Example: DOCS_Admins=admin,DOCS_Editors=editor,DOCS_Readers=viewer
LDAP_GROUP_ROLE_MAP=DOCS_Admins=admin,DOCS_Editors=editor,DOCS_Readers=viewer

# App
APP_HOST=0.0.0.0
APP_PORT=3001
NODE_ENV=development
PORT=3001
